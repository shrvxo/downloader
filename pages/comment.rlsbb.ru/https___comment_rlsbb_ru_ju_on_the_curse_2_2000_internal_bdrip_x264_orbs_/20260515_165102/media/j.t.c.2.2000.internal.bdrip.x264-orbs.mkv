        <!-- UI Scripts -->
        <script type="text/javascript">
            $(document).ready(function() {
                $("#showallarch").click(function() {
                    $(this).css('display', 'none');
                    $("#fileinfoarch").css('height', '100%');
                    $("#grad").css('display', 'none');
